;;; ======================================================
;;; 4. ПРАВИЛА ПОЛЬЗОВАТЕЛЬСКОГО ИНТЕРФЕЙСА
;;; ======================================================

;;; Приветственное сообщение
(defrule приветствие
   (declare (salience 1000))
   (not (приветствие-показано))
   =>
   (assert (приветствие-показано))
   (printout t crlf)
   (printout t "╔══════════════════════════════════════════════════════════════╗" crlf)
   (printout t "║              ПОМОЩНИК ПО ВЫБОРУ АВТОМОБИЛЯ                  ║" crlf)
   (printout t "║                    Экспертная система                        ║" crlf)
   (printout t "╚══════════════════════════════════════════════════════════════╝" crlf)
   (printout t crlf)
   (printout t "Данная система поможет вам выбрать лучший автомобиль на основе:" crlf)
   (printout t "  • Вашего бюджета" crlf)
   (printout t "  • Потребностей в вождении" crlf)
   (printout t "  • Технических предпочтений" crlf)
   (printout t "  • Ожиданий по обслуживанию" crlf)
   (printout t crlf)
   (printout t "Пожалуйста, внимательно ответьте на следующие вопросы." crlf)
   (printout t "=================================================================" crlf crlf)
)

;;; Задать вопрос
(defrule задать-вопрос
   ?в <- (вопрос (идентификатор ?ид) (текст ?текст) (варианты ?опции) (задан нет))
   (not (потребность-пользователя (категория ?ид)))
   =>
   (retract ?в)
   (printout t crlf "❓ " ?текст crlf)
   (printout t "   Варианты: " ?опции crlf)
   (printout t "   Ваш ответ: ")
   (bind ?ответ (readline))
   (bind ?ответ (lowcase ?ответ))
   
   (if (or (eq ?ответ "низкий") (eq ?ответ "средний") (eq ?ответ "высокий")
           (eq ?ответ "премиум") (eq ?ответ "город") (eq ?ответ "трасса")
           (eq ?ответ "бездорожье") (eq ?ответ "семья") (eq ?ответ "работа")
           (eq ?ответ "бензин") (eq ?ответ "дизель") (eq ?ответ "электричество")
           (eq ?ответ "гибрид") (eq ?ответ "механика") (eq ?ответ "автомат")
           (eq ?ответ "вариатор") (eq ?ответ "робот") (eq ?ответ "передний")
           (eq ?ответ "задний") (eq ?ответ "полный") (eq ?ответ "2-3")
           (eq ?ответ "4-5") (eq ?ответ "6-7+") (eq ?ответ "маленький")
           (eq ?ответ "средний") (eq ?ответ "большой") (eq ?ответ "новый")
           (eq ?ответ "молодой") (eq ?ответ "старый") (eq ?ответ "низкие")
           (eq ?ответ "средние") (eq ?ответ "высокие"))
      then
      (assert (потребность-пользователя (категория ?ид) (значение ?ответ)))
      (printout t "   ✓ Выбрано: " ?ответ crlf)
      (assert (вопрос (идентификатор ?ид) (текст ?текст) (варианты ?опции) (задан да)))
   else
      (printout t "   ✗ Неверный ввод. Пожалуйста, выберите из предложенных вариантов." crlf)
      (assert (вопрос (идентификатор ?ид) (текст ?текст) (варианты ?опции) (задан нет)))
   )
)

;;; Показать рекомендации
(defrule показать-рекомендации
   (declare (salience -50))
   (рекомендация-авто (модель ?модель) (тип ?тип) (цена ?цена)
                      (топливо ?топливо) (надежность ?надеж) (причина ?причина) (уверенность ?увер))
   (not (рекомендации-показаны))
   =>
   (assert (рекомендации-показаны))
   (printout t crlf)
   (printout t "╔══════════════════════════════════════════════════════════════╗" crlf)
   (printout t "║                    РЕКОМЕНДАЦИЯ                              ║" crlf)
   (printout t "╚══════════════════════════════════════════════════════════════╝" crlf)
   (printout t crlf)
   (printout t "🏆 РЕКОМЕНДУЕМЫЙ АВТОМОБИЛЬ: " ?модель crlf)
   (printout t "────────────────────────────────────────────────────────────" crlf)
   (printout t "  Тип:         " ?тип crlf)
   (printout t "  Цена:        " ?цена crlf)
   (printout t "  Топливо:     " ?топливо crlf)
   (printout t "  Надежность:  " ?надеж "/10" crlf)
   (printout t "  Уверенность: " ?увер "%" crlf)
   (printout t "────────────────────────────────────────────────────────────" crlf)
   (printout t "  Почему этот автомобиль?" crlf)
   (printout t "  → " ?причина crlf)
   (printout t crlf)
)

;;; Показать альтернативную рекомендацию
(defrule показать-альтернативу
   (declare (salience -51))
   ?р2 <- (рекомендация-авто (модель ?модель) (тип ?тип) (цена ?цена)
                             (топливо ?топливо) (надежность ?надеж) (причина ?причина) (уверенность ?увер))
   (рекомендации-показаны)
   (not (альтернатива-показана))
   =>
   (assert (альтернатива-показана))
   (printout t crlf)
   (printout t "🔄 АЛЬТЕРНАТИВНЫЙ ВАРИАНТ:" crlf)
   (printout t "────────────────────────────────────────────────────────────" crlf)
   (printout t "  Модель:      " ?модель crlf)
   (printout t "  Тип:         " ?тип crlf)
   (printout t "  Цена:        " ?цена crlf)
   (printout t "  Топливо:     " ?топливо crlf)
   (printout t "  Надежность:  " ?надеж "/10" crlf)
   (printout t "  Уверенность: " ?увер "%" crlf)
   (printout t "────────────────────────────────────────────────────────────" crlf)
   (printout t "  → " ?причина crlf)
   (printout t crlf)
)

;;; Финальные советы
(defrule финальные-советы
   (declare (salience -100))
   (рекомендации-показаны)
   (not (финал-показан))
   =>
   (assert (финал-показан))
   (printout t "╔══════════════════════════════════════════════════════════════╗" crlf)
   (printout t "║                    СЛЕДУЮЩИЕ ШАГИ                            ║" crlf)
   (printout t "╚══════════════════════════════════════════════════════════════╝" crlf)
   (printout t crlf)
   (printout t "Перед покупкой рекомендуется:" crlf)
   (printout t "  1. Совершить тест-драйв рекомендуемых моделей" crlf)
   (printout t "  2. Почитать реальные отзывы владельцев" crlf)
   (printout t "  3. Сравнить стоимость страховки и налога" crlf)
   (printout t "  4. Рассмотреть сертифицированные автомобили с пробегом" crlf)
   (printout t "  5. Провести независимую диагностику для подержанных авто" crlf)
   (printout t crlf)
   (printout t "Спасибо за использование Помощника по выбору автомобиля!" crlf)
   (printout t "================================================================" crlf)
   (halt)
)

;;; Конец базы знаний
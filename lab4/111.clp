   (потребность-пользователя (категория назначение) (значение трасса))
   (потребность-пользователя (категория кпп) (значение автомат))
   (потребность-пользователя (категория обслуживание) (значение средние))
   =>
   (assert (рекомендация-авто 
            (модель "Тойота Камри")
            (тип "Бизнес-седан")
            (цена "2.5 - 3.5 млн руб. (новый) / 1.5-2.5 млн руб. (с пробегом)")
            (топливо "Бензин")
            (надежность 9)
            (причина "Легендарная надежность, комфорт для дальних поездок, высокая ликвидность")
            (уверенность 95)))
)


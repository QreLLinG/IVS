;;; ======================================================
;;; ЭКСПЕРТНАЯ СИСТЕМА: Помощник по выбору автомобиля
;;; 
;;; Данная экспертная система рекомендует автомобиль
;;; на основе предпочтений и требований пользователя.
;;;
;;; Для запуска: load, reset, run
;;; ======================================================

;;; ======================================================
;;; 1. ШАБЛОНЫ (DEFTEMPLATES) - Структуры данных
;;; ======================================================

(deftemplate потребность-пользователя
   (slot категория)      ; бюджет, назначение, топливо и т.д.
   (slot значение)       ; выбранное значение
)

(deftemplate рекомендация-авто
   (slot модель)         ; модель автомобиля
   (slot тип)            ; тип автомобиля
   (slot цена)           ; ценовая категория
   (slot топливо)        ; тип топлива
   (slot надежность)     ; оценка надежности 1-10
   (slot причина)        ; причина рекомендации
   (slot уверенность)    ; уверенность 0-100
)

(deftemplate вопрос
   (slot идентификатор)  ; ID вопроса
   (slot текст)          ; текст вопроса
   (slot варианты)       ; доступные варианты
   (slot задан)          ; задан ли вопрос
)

;;; ======================================================
;;; 2. НАЧАЛЬНЫЕ ФАКТЫ (DEFFACTS) - Вопросы
;;; ======================================================

(deffacts начальные-вопросы
   
   ; Вопрос 1: Бюджет
   (вопрос (идентификатор бюджет) 
           (текст "Какой у вас бюджет на покупку автомобиля?") 
           (варианты "низкий (до 500 тыс. руб.) | средний (500 тыс. - 1 млн руб.) | высокий (1-2 млн руб.) | премиум (более 2 млн руб.)")
           (задан нет))
   
   ; Вопрос 2: Основное назначение
   (вопрос (идентификатор назначение) 
           (текст "Для каких целей вы будете использовать автомобиль?") 
           (варианты "город (ежедневные поездки) | трасса (дальние поездки) | бездорожье | семья | работа")
           (задан нет))
   
   ; Вопрос 3: Годовой пробег
   (вопрос (идентификатор пробег) 
           (текст "Какой у вас планируемый годовой пробег?") 
           (варианты "низкий (до 10 тыс. км) | средний (10-20 тыс. км) | высокий (более 20 тыс. км)")
           (задан нет))
   
   ; Вопрос 4: Тип топлива
   (вопрос (идентификатор топливо) 
           (текст "Какой тип топлива вы предпочитаете?") 
           (варианты "бензин | дизель | электричество | гибрид")
           (задан нет))
   
   ; Вопрос 5: Коробка передач
   (вопрос (идентификатор кпп) 
           (текст "Какую коробку передач вы предпочитаете?") 
           (варианты "механика | автомат | вариатор | робот")
           (задан нет))
   
   ; Вопрос 6: Тип привода
   (вопрос (идентификатор привод) 
           (текст "Какой тип привода вам нужен?") 
           (варианты "передний | задний | полный")
           (задан нет))
   
   ; Вопрос 7: Вместимость
   (вопрос (идентификатор пассажиры) 
           (текст "Сколько пассажиров вам нужно перевозить?") 
           (варианты "2-3 | 4-5 | 6-7+")
           (задан нет))
   
   ; Вопрос 8: Объем багажника
   (вопрос (идентификатор багажник) 
           (текст "Насколько важен объем багажника?") 
           (варианты "маленький (только продукты) | средний (поездки на выходные) | большой (мебель/инструменты)")
           (задан нет))
   
   ; Вопрос 9: Возраст автомобиля
   (вопрос (идентификатор возраст) 
           (текст "Какой возраст автомобиля вы предпочитаете?") 
           (варианты "новый (0-1 год) | молодой (2-3 года) | средний (4-7 лет) | старый (8+ лет)")
           (задан нет))
   
   ; Вопрос 10: Стоимость обслуживания
   (вопрос (идентификатор обслуживание) 
           (текст "Какие расходы на обслуживание вы можете позволить?") 
           (варианты "низкие | средние | высокие")
           (задан нет))
)

;;; ======================================================
;;; 3. ПРАВИЛА - База знаний для рекомендаций
;;; ======================================================

;;; ----------------------------------------------
;;; ПРАВИЛО 1: Бюджетный городской автомобиль
;;; ----------------------------------------------
(defrule рекомендовать-солярис-рио
   (declare (salience 100))
   (потребность-пользователя (категория бюджет) (значение низкий))
   (потребность-пользователя (категория назначение) (значение город))
   (потребность-пользователя (категория топливо) (значение бензин))
   (потребность-пользователя (категория обслуживание) (значение низкие))
   =>
   (assert (рекомендация-авто 
            (модель "Хендай Солярис / Киа Рио")
            (тип "Бюджетный городской хэтчбек")
            (цена "500-900 тыс. руб. (новый) / 300-500 тыс. руб. (с пробегом)")
            (топливо "Бензин")
            (надежность 8)
            (причина "Отличное соотношение цены и качества, низкие расходы на обслуживание, идеален для города")
            (уверенность 90)))
   
   (printout t crlf "*** НАЙДЕНА РЕКОМЕНДАЦИЯ ***" crlf)
)

;;; ----------------------------------------------
;;; ПРАВИЛО 2: Бюджетный семейный автомобиль
;;; ----------------------------------------------
(defrule рекомендовать-веста
   (declare (salience 95))
   (потребность-пользователя (категория бюджет) (значение низкий))
   (потребность-пользователя (категория назначение) (значение семья))
   (потребность-пользователя (категория обслуживание) (значение низкие))
   (потребность-пользователя (категория багажник) (значение средний))
   =>
   (assert (рекомендация-авто 
            (модель "Лада Веста СВ / Седан")
            (тип "Бюджетный семейный автомобиль")
            (цена "700 тыс. - 1.2 млн руб. (новый) / 400-700 тыс. руб. (с пробегом)")
            (топливо "Бензин")
            (надежность 7)
            (причина "Просторный салон, большой багажник, дешевые запчасти, хороший дорожный просвет")
            (уверенность 85)))
)

;;; ----------------------------------------------
;;; ПРАВИЛО 3: Бизнес-седан
